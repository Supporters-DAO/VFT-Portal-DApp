{
  "name": "squid",
  "private": true,
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "rm -rf lib && tsc",
    "run": "sqd process",
    "migrations:generate": "sqd migration:generate",
    "migrations:apply": "sqd migration:apply",
    "serve": "squid-graphql-server serve",
    "serve:prod": "squid-graphql-server --subscriptions --dumb-cache in-memory --dumb-cache-ttl 1000 --dumb-cache-size 100 --dumb-cache-max-age 1000",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "npm run migrations:apply && node lib/main.js"
  },
  "dependencies": {
    "@subsquid/graphql-server": "4.11.0",
    "@subsquid/substrate-processor": "8.6.1",
    "@subsquid/typeorm-migration": "1.3.0",
    "@subsquid/typeorm-store": "1.7.0",
    "dotenv": "17.3.1",
    "lodash": "4.17.23",
    "pg": "8.19.0",
    "sails-js": "0.5.1",
    "sails-js-parser": "0.5.1",
    "typeorm": "0.3.28"
  },
  "devDependencies": {
    "@subsquid/substrate-metadata-explorer": "3.2.0",
    "@subsquid/substrate-typegen": "8.1.0",
    "@subsquid/typeorm-codegen": "2.0.2",
    "@types/lodash": "4.17.24",
    "@types/node": "25.3.3",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "eslint": "10.0.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "overrides": {
    "@polkadot/util": "14.0.1"
  }
}
